{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Kubernetes LLM Platform",
  "colors": {
    "primary": "#326CE5",
    "light": "#315F56",
    "dark": "#9DBBFF"
  },
  "logo": {
    "light": "/assets/brand/kubernetes-inference-light.svg",
    "dark": "/assets/brand/kubernetes-inference-dark.svg",
    "href": "/"
  },
  "favicon": "/assets/brand/kubernetes-inference-mark.svg",
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "IBM Plex Sans",
      "weight": 600
    },
    "body": {
      "family": "IBM Plex Sans",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#FAFBF7",
      "dark": "#101417"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false,
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://ai.wmx.dev"
    }
  },
